{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run TSZ VS Code Client",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/scripts/vscode-tsz-lsp"
      ],
      "outFiles": [
        "${workspaceFolder}/scripts/vscode-tsz-lsp/out/**/*.js"
      ],
      "preLaunchTask": "prepare tsz vscode demo"
    }
  ]
}