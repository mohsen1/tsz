#!/bin/bash
#
# post-rewrite hook for tsz
#
# Handles pull --rebase flows where post-merge is not triggered.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../" && pwd)"

if [ "${TSZ_GIT_HOOK_RESET_TYPESCRIPT:-}" = "1" ]; then
    "$ROOT_DIR/scripts/setup/reset-ts-submodule.sh"
fi
