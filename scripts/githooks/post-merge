#!/bin/bash
#
# post-merge hook for tsz
#
# Git does not have a dedicated "post-pull" hook. post-merge runs after
# pull when pull performs a merge.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../" && pwd)"

if [ "${TSZ_GIT_HOOK_RESET_TYPESCRIPT:-}" = "1" ]; then
    "$ROOT_DIR/scripts/setup/reset-ts-submodule.sh"
fi
