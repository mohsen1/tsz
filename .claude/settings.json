{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(cargo *)",
      "Bash(git *)",
      "Bash(./scripts/*)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "Bash(stat *)",
      "Bash(test *)",
      "Bash(flock *)",
      "Bash(cd *)",
      "Bash(gh *)",
      "Bash(chmod *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tee *)",
      "Bash(xargs *)",
      "Bash(touch *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(pwd)",
      "Bash(env *)",
      "Bash(which *)",
      "Bash(rm *)",
      "Task(**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: commit and sync with main when work is done.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull --rebase origin main 2>/dev/null; cat \"$CLAUDE_PROJECT_DIR/AGENTS.md\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | grep -q '\\.rs$' && cargo fmt --quiet || exit 0"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Claude Code is waiting for attention (idle prompt). Make sure to commit and sync with main when work is done."
          }
        ]
      }
    ],
    "PreToolUse": []
  },
  "enabledPlugins": {
    "explanatory-output-style@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}
