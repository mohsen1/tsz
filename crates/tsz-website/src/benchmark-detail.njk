---
layout: layouts/base.njk
page_class: benchmark-detail
extra_scripts: <script src="/benchmark-source-viewer.js" defer></script>
pagination:
  data: benchmark_pages
  size: 1
  alias: benchmark
permalink: "benchmarks/{{ benchmark.slug }}/index.html"
eleventyComputed:
  title: "{{ benchmark.display_name }} Benchmark"
---

<nav class="bench-breadcrumb" aria-label="Breadcrumb">
  <a href="/benchmarks/">Benchmarks</a>
</nav>

<h1>{{ benchmark.display_name }}</h1>
{% if benchmark.detail_focus %}
  <p class="subtitle">{{ benchmark.detail_focus }}</p>
{% endif %}

<div class="bench-detail-hero">
  <div class="bench-detail-result">
    {% if benchmark.comparison.available %}
      <strong>
        {% if benchmark.speedup_label == "equal" %}
          equal
        {% else %}
          {{ benchmark.speedup_label | replace("tsz ", "tsz is ") | replace("tsgo ", "tsgo is ") }}
        {% endif %}
      </strong>
      <span>
        {% if benchmark.comparison.winner == "tsz" %}
          tsz leads this benchmark.
        {% elif benchmark.comparison.winner == "tsgo" %}
          tsgo leads this benchmark.
        {% else %}
          Both compilers are effectively tied.
        {% endif %}
      </span>
    {% else %}
      <strong>tsz unavailable</strong>
      <span>{{ benchmark.status or "No timing was recorded for tsz." }}</span>
    {% endif %}
  </div>
</div>

<section class="bench-detail-grid" aria-label="Benchmark measurements">
  <div class="bench-metric">
    <span>tsz</span>
    <strong>{% if benchmark.tsz_ms %}{{ benchmark.tsz_ms }}ms{% else %}n/a{% endif %}</strong>
  </div>
  <div class="bench-metric">
    <span>tsgo</span>
    <strong>{% if benchmark.tsgo_ms %}{{ benchmark.tsgo_ms }}ms{% else %}n/a{% endif %}</strong>
  </div>
  <div class="bench-metric">
    <span>Lines</span>
    <strong>{{ benchmark.lines or 0 }}</strong>
  </div>
  <div class="bench-metric">
    <span>Size</span>
    <strong>{{ benchmark.kb or 0 }} KB</strong>
  </div>
</section>

<section>
  <h2>Timing</h2>
  <div class="bench-detail-bars">
    <div class="bench-bar-row">
      <span class="bench-bar-label">tsz</span>
      <div class="bench-detail-meter">
        <span class="bench-detail-fill tsz" style="width: {{ benchmark.tsz_width }}%"></span>
      </div>
      <span class="bench-detail-time">{% if benchmark.tsz_time %}{{ benchmark.tsz_time }}{% else %}failed{% endif %}</span>
    </div>
    <div class="bench-bar-row">
      <span class="bench-bar-label">tsgo</span>
      <div class="bench-detail-meter">
        <span class="bench-detail-fill tsgo" style="width: {{ benchmark.tsgo_width }}%"></span>
      </div>
      <span class="bench-detail-time">{% if benchmark.tsgo_time %}{{ benchmark.tsgo_time }}{% else %}n/a{% endif %}</span>
    </div>
  </div>
</section>

{% if benchmark.source_files.length %}
  <section id="benchmark-files">
    <h2>Files</h2>
    <div class="benchmark-source-viewer" data-files="{{ benchmark.source_files_json | safe }}">
      <div class="benchmark-source-tabs" role="tablist" aria-label="Benchmark files"></div>
      <div class="benchmark-source-editor" aria-label="Benchmark source viewer">
        <pre class="bench-snippet"><code>{{ benchmark.snippet }}</code></pre>
      </div>
    </div>
  </section>
{% endif %}
